<!DOCTYPE html>
<html lang="ru" id="htmlTheme">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HFFreelance | Авторизация</title>
    <link rel="stylesheet" href="/stylesheets/login-register.css">
    <link rel="stylesheet" href="/stylesheets/alert.css">
    <link rel="icon" type="image/png" href="/images/icon.png">
</head>
<body>
<form action="/auth/login" method="POST" id="loginForm">
    <div class="card-container">

        <div class="container">
            <div class="log-card">
                <div style="display: flex; gap: 10px; margin-left: -10px;">
                    <a href="/" style="text-decoration: none"><h1>&#11013;</h1></a>
                    <p class="heading">Добро пожаловать!</p>
                </div>
                <p class="welcome">Мы рады видеть вас снова!</p>

                <div class="input-group">
                    <p class="text">Эл. адрес</p>
                    <input class="input" type="email" name="email" id="email" placeholder="Введите Эл. адрес" required>
                    <p class="text">Пароль</p>
                    <input class="input" type="password" id="pwd" name="password" placeholder="Введите пароль" required>
                    <img src="/images/invisiblePassword.png" class="toggle-password" style="top: 56%;" id="togglePassword1">
                    <img src="/images/visiblePassword.png" class="toggle-password" style="top: 56%;" id="togglePassword2" hidden>
                </div>

                <div class="password-group">
                    <div class="checkbox-group">
                        <input type="checkbox" id="rememberMeCheckbox">
                        <label class="remember-me" for="rememberMeCheckbox">Запомнить меня</label>
                    </div>
                    <a href="/auth/forget-password" class="forget-password">Я забыл проль</a>
                </div>

                <button type="submit" class="btn" id="loginButton">Войти</button>
                <div class="btn" style="height: 18px;" id="loaderButton" hidden>
                    <section class="dots-container">
                        <div class="dot"></div>
                        <div class="dot"></div>
                        <div class="dot"></div>
                        <div class="dot"></div>
                    </section>
                </div>

                <span id="loginErr" style="text-align: center"></span>
                <span id="correctJoin" style="text-align: center"></span>

                <p class="no-account">У вас ещё нет аккаунта?<a href="/auth/register" class="link"> Создать</a></p>
            </div>
        </div>
    </div>
</form>
<script src="/javascripts/auth/login.js"></script>
<script src="/javascripts/alert.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>
</html>