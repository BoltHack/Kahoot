<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title> <%= companion.role === 'TechSupport' ? 'Тех поддержка - ' + companion.name : companion.role === 'Admin' ? 'Админ - ' + companion.name : 'Чат с ' + companion.name %> </title>
    <link rel="stylesheet" href="/stylesheets/channels.css">
    <link rel="stylesheet" href="/stylesheets/alert.css">
    <link rel="icon" type="image/png" href="/images/icon.png">
    <noscript>
        <%- include('./tools/noscript.ejs') %>
    </noscript>
</head>
<script>
    const sendId = `<%= myData.id %>`;
    const sendName = `<%= myData.name %>`;
    const channelId = `<%= channel._id %>`;
    const localeType = `<%= locale %>`;
    const companionId = `<%= companion.id %>`;
    const pushNotifications = `<%= notifications %>`;
</script>
<body>
<div class="layout">
    <div class="sidebar">
        <a class="home" href="/">На главную</a>
        <div class="sidebar-header">Опции</div>
        <ul class="chat-tools">
            <li>
                <a class="chat-tool" id="friendsContainerBtn" onclick="friendsContainerFunc()">Друзья</a>
                <a class="chat-tool" id="addFriendBtn" onclick="addFriendFunc()">Добавить друга</a>
            </li>
        </ul>
        <br>
        <div class="sidebar-line"></div>
        <br>
        <div class="sidebar-header">Личные сообщения</div>
        <% if (myChannels && myChannels.length) { %>
            <ul class="chat-list">
                <% myChannels.forEach(channels => { %>
                    <li class="close-btn missed-messages-count-<%= channels.channelId %>" id="closeBtn-<%= channels.channelId %>" onmouseover="showCloseBtn('<%= channels.channelId %>')">
                        <% if (channel._id.toString() === channels.channelId.toString()) { %>
                            <a class="chat-link chat-selected">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-circle-more-icon lucide-message-circle-more"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/><path d="M8 12h.01"/><path d="M12 12h.01"/><path d="M16 12h.01"/></svg>
                                <span class="link-companion"><%= channels.companionName %></span>
                                <span class="del-companion" onclick="deleteMyChannel('<%= channels.channelId %>')">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x-icon lucide-x"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                                </span>
                                <span class="missed-messages"></span>
                            </a>
                        <% } else { %>
                            <a class="chat-link" href="/channels/@me/<%= channels.channelId %>">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-circle-more-icon lucide-message-circle-more"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/><path d="M8 12h.01"/><path d="M12 12h.01"/><path d="M16 12h.01"/></svg>
                                <span class="link-companion"><%= channels.companionName %></span>
                                <span class="del-companion" onclick="deleteMyChannel('<%= channels.channelId %>')">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x-icon lucide-x"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                                </span>
                                <span class="missed-messages"></span>
                            </a>
                        <% } %>
                    </li>
                <% }) %>
            </ul>
        <% } %>
    </div>

    <div class="chat-container" id="chat-container">
        <div class="chat-header">
            <div class="chat-position">
                <div class="avatar-position" onclick="window.location.href = '/user-profile/<%= companion.id %>'">
                    <img class="avatar header-avatar" src="<%= companion.image %>">
                    <span class="chat-name <%= companion.role === 'TechSupport' ? `tech-chat` : '' %>"><%= companion.name %></span>
                </div>
                <div class="chat-name-role">
                    <% if (companion.role === 'Admin') { %>
                        <div class="tooltip-container">
                            <a class="friend-btn delete">
                                <div class="tooltip-btn">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user-star-icon lucide-user-star">
                                        <path d="M16.051 12.616a1 1 0 0 1 1.909.024l.737 1.452a1 1 0 0 0 .737.535l1.634.256a1 1 0 0 1 .588 1.806l-1.172 1.168a1 1 0 0 0-.282.866l.259 1.613a1 1 0 0 1-1.541 1.134l-1.465-.75a1 1 0 0 0-.912 0l-1.465.75a1 1 0 0 1-1.539-1.133l.258-1.613a1 1 0 0 0-.282-.866l-1.156-1.153a1 1 0 0 1 .572-1.822l1.633-.256a1 1 0 0 0 .737-.535z"/><path d="M8 15H7a4 4 0 0 0-4 4v2"/><circle cx="10" cy="7" r="4"/>
                                    </svg>
                                </div>
                                <div role="tooltip" class="tooltip t-bottom">
                                    <span>Админ</span>
                                </div>
                            </a>
                        </div>
                    <% } else if (companion.role === 'TechSupport') { %>
                            <div class="tooltip-container">
                                <a class="friend-btn delete">
                                    <div class="tooltip-btn">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-wrench-icon lucide-wrench">
                                            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.106-3.105c.32-.322.863-.22.983.218a6 6 0 0 1-8.259 7.057l-7.91 7.91a1 1 0 0 1-2.999-3l7.91-7.91a6 6 0 0 1 7.057-8.259c.438.12.54.662.219.984z"/>
                                        </svg>
                                    </div>
                                    <div role="tooltip" class="tooltip t-bottom">
                                        <span>Тех поддержка</span>
                                    </div>
                                </a>
                            </div>
                    <% } else { %>
                            <div class="tooltip-container">
                                <a class="friend-btn delete">
                                    <div class="tooltip-btn">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user-icon lucide-user">
                                            <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                                        </svg>
                                    </div>
                                    <div role="tooltip" class="tooltip t-bottom">
                                        <span>Игрок</span>
                                    </div>
                                </a>
                            </div>
                    <% } %>
                </div>
                <span id="onlineMod">Загрузка...</span>
                <div class="channel-tools">
                    <div class="media-width">
                        <input hidden="" class="check-icon" id="check-icon" name="check-icon" type="checkbox" onclick="mediaMenu()">
                        <label class="icon-menu" for="check-icon">
                            <div class="bar bar--1"></div>
                            <div class="bar bar--2"></div>
                            <div class="bar bar--3"></div>
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <div class="chat-messages" id="messages">
            <div class="companion-info">
                <img src="<%= companion.image %>">
                <h2><%= companion.name %></h2>
                <p>Это начало истории ваших личных сообщений с <strong><%= companion.name %></strong>.</p>
                <% if ( myData.myFriends.some(friend => friend.id.toString() === companion.id.toString()) ) { %>
                    <button class="btn" id="deleteFriend" onclick="deleteFriend('<%= companion.id %>', '<%= companion.name %>')">➖ Удалить из друзей</button>
                <% } else { %>
                    <button class="btn" id="addFriend" onclick="addFriend('<%= companion.name %>')">➕ Добавить в друзья</button>
                <% } %>
                <div class="chat-line">
                    <div></div>
                    <span>
                        <%= (() => {
                            const d = new Date(channel.date);
                            const now = new Date();

                            const isSameDay = (d1, d2) =>
                                    d1.getDate() === d2.getDate() &&
                                    d1.getMonth() === d2.getMonth() &&
                                    d1.getFullYear() === d2.getFullYear();

                            const yesterday = new Date(now);
                            yesterday.setDate(now.getDate() - 1);

                            if (isSameDay(d, now)) {
                                return 'Сегодня, ' + d.toLocaleTimeString('ru-RU', {hour: '2-digit', minute: '2-digit', hour12: false});
                            } else if (isSameDay(d, yesterday)) {
                                return 'Вчера, ' + d.toLocaleTimeString('ru-RU', {hour: '2-digit', minute: '2-digit', hour12: false});
                            } else {
                                return d.toLocaleString('ru-RU', {
                                    day: '2-digit',
                                    month: 'long',
                                    year: 'numeric'
                                });
                            }
                        })() %>
                    </span>
                    <div></div>
                </div>

                <div id="top-sentinel"></div>
            </div>
            <div class="loaderMessages">
                <div class="load-message is-loading">
                    <div class="message-container">
                        <div class="avatar"></div>
                        <div class="message-content">
                            <div class="message-header">
                                <span class="username"></span>
                                <span class="timestamp"></span>
                            </div>
                            <div class="msg-content">
