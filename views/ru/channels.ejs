<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Чат с <%= channel.channelUsers[0].id !== user.id ? channel.channelUsers[0].name : channel.channelUsers[1].name %> </title>
    <link rel="stylesheet" href="/stylesheets/channels.css">
    <link rel="icon" type="image/png" href="/images/icon.png">
</head>
<script>
    const sendId = `<%= user.id %>`;
    const sendName = `<%= user.name %>`;
    const channelId = `<%= channel._id %>`;
    const localeType = `<%= locale %>`;
</script>
<body>

<div class="chat-header">
    <span style="color: #adb5bd">
        # <%= channel.channelUsers[0].id !== user.id ? channel.channelUsers[0].name : channel.channelUsers[1].name %>
    </span>
    <span style="margin-left: 20px;" id="onlineMod"></span>
    <a class="home" href="/">На главную</a>
</div>

<div class="chat-messages" id="messages">
    <% if (channel.messages && channel.messages.length) { %>
        <% channel.messages.forEach(msg => { %>
            <div class="message">
                <img class="avatar" src="<%= msg.id === user1.id ? user1.image : user2.image %>">
                <div class="message-content">
                    <div class="message-header">
                        <span class="username"><%= msg.name %></span>
                        <span class="timestamp">
                            <%= (() => {
                                const d = new Date(msg.date);
                                const now = new Date();

                                const isSameDay = (d1, d2) =>
                                        d1.getDate() === d2.getDate() &&
                                        d1.getMonth() === d2.getMonth() &&
                                        d1.getFullYear() === d2.getFullYear();

                                const yesterday = new Date(now);
                                yesterday.setDate(now.getDate() - 1);

                                if (isSameDay(d, now)) {
                                    return 'Сегодня, ' + d.toLocaleTimeString('ru-RU', {hour: '2-digit', minute: '2-digit', hour12: false});
                                } else if (isSameDay(d, yesterday)) {
                                    return 'Вчера, ' + d.toLocaleTimeString('ru-RU', {hour: '2-digit', minute: '2-digit', hour12: false});
                                } else {
                                    return d.toLocaleString('ru-RU', {
                                        day: '2-digit',
                                        month: 'long',
                                        year: 'numeric',
                                        hour: '2-digit',
                                        minute: '2-digit',
                                        hour12: false
                                    });
                                }
                            })() %>


                        </span>
                    </div>

                    <div class="text"><%- msg.message %></div>
                </div>
            </div>
        <% }) %>
    <% } %>
</div>

<div class="chat-input">
    <input type="text" placeholder="Написать сообщение..." id="message" autocomplete="off" />
    <button onclick="sendMessage()">Отправить</button>
</div>
<script src="/socket.io/socket.io.js"></script>
<script src="/javascripts/channels.js"></script>
<script src="/javascripts/friends.js"></script>
</body>
</html>