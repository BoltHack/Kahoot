                    <div class="message-container">
                        <div class="avatar"></div>
                        <div class="message-content">
                            <div class="message-header">
                                <span class="username"></span>
                                <span class="timestamp"></span>
                            </div>
                            <div class="msg-content">
                                <div class="text"></div>
                            </div>
