                    <div class="message-container">
                        <div class="avatar"></div>
                        <div class="message-content">
                            <div class="message-header">
                                <span class="username"></span>
                                <span class="timestamp"></span>
                            </div>
                            <div class="msg-content">
                                <div class="text"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <template id="message-template">
                <div class="message" data-id="" id="">
                    <div class="message-container">
                        <img class="avatar" src="">
                        <div class="message-content">

                            <div class="reply-wrapper" style="display: none;">

                                <a class="reply-container reply-active" style="display: none;">
                                    <div class="reply-line-wrapper">
                                        <div class="reply-line"></div>
                                        <img class="reply-avatar" src="">
                                    </div>
                                    <div class="reply-text-container">
                                        <div class="reply-header"><strong class="reply-name"></strong></div>
                                        <div class="reply-text"></div>
                                    </div>
                                </a>

                                <a class="reply-container reply-deleted" style="display: none;">
                                    <div class="reply-line-wrapper">
                                        <div class="reply-line" style="margin-right: 10px; height: 15px;"></div>
                                        <br/>
                                    </div>
                                    <div class="reply-text-container">
                                        <div class="reply-text">Оригинальное сообщение удалено</div>
                                    </div>
                                </a>

                                <a class="reply-container reply-not-loaded" style="display: none;">
