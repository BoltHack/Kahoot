<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>News | <%= readNews.updateTitle %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/stylesheets/news.css">
    <link rel="icon" type="image/png" href="/images/icon.png">
</head>
<script>
    const newsTitle = '<%= readNews.updateTitle %>';
</script>
<body>
<%- include('header.ejs') %>
<main>
    <div class="sticky-container" id="stickyHeight">
        <div class="sticky">
            <div class="sticky-box">
                <h3>Our social networks</h3>
                <div class="social-buttons">
                    <a href="https://www.facebook.com/sharer/sharer.php?u=<%= readNews.url %>" target="_blank" class="social-btn facebook">
                        <span class="icon">&#xf09a;</span> Facebook
                    </a>
                    <a href="https://twitter.com/intent/tweet?text=<%= readNews.title %>&url=<%= readNews.url %>" target="_blank" class="social-btn twitter">
                        <span class="icon">&#xf099;</span> Twitter
                    </a>
                    <a href="https://vk.com/share.php?url=<%= readNews.url %>" target="_blank" class="social-btn vk">
                        <span class="icon">&#xf189;</span> VK
                    </a>
                    <a href="https://www.pinterest.com/pin/create/button/?url=<%= readNews.url %>&media=<%= readNews.imageUrl %>&description=<%= readNews.title %>" target="_blank" class="social-btn pinterest">
                        <span class="icon">&#xf0d2;</span> Pinterest
                    </a>
                    <a href="mailto:?subject=<%= readNews.title %>&body=<%= readNews.url %>" target="_blank" class="social-btn email">
                        <span class="icon">&#xf0e0;</span> Email
                    </a>
                    <button id="copyLinkBtn" class="social-btn copy-link">
                        <span class="icon">&#xf0c5;</span> Copy page address
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="news-container writeNews">
            <article class="news-card">
                <h2 class="news-title"><%= readNews.updateTitle %></h2>
                <div class="news-meta">
                    <div class="news-author" style="margin-left: 55px;">
                        <img src="data:image/png;base64,<%= readNews.author.authorImage %>">
                        <span><%= readNews.author.authorName %></span>
                    </div>
                    <span class="news-date">📅 <%= readNews.date %></span>
                </div>
                <% if (readNews.update && Array.isArray(readNews.update) && readNews.update.length > 0) { %>
                    <% readNews.update.forEach(updateNews => { %>
                        <h3><%= updateNews.title %></h3>
                        <% if (updateNews.image) { %>
                            <div class="news-image" style="margin-top: -30px;">
                                <img src="data:image/png;base64,<%= updateNews.image %>" alt="Новость">
                            </div>
                        <% } %>
                        <p class="news-summary"><%= updateNews.content %></p>
                    <br>
                    <br>
                    <% }) %>
                <% } %>
                <div class="news-footer">
                    <div class="stats">
                        <span style="font-size: 25px; font-weight: 600">&#128065;</span>
                        <p style="margin-top: 11.5px;"><%= readNews.views %></p>
                    </div>
                </div>
            </article>
        </div>
    </div>
</main>
<br>
<br>
<br>
<br>
<%- include('footer.ejs') %>
<script src="/javascripts/timer.js"></script>
<script src="/javascripts/readNews.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>
</html>
